# Example environment configuration for Gift Portal Backend
# Copy this file to .env and fill in your values

# ==============================================================================
# Exa API Configuration
# ==============================================================================
# Get your API key from: https://exa.ai/
EXA_API_KEY=your-exa-api-key-here

# Mock Mode (saves API credits during development)
# Set to 'true' to use mock data instead of real Exa API calls
# Set to 'false' to use real Exa API (requires valid API key and credits)
MOCK_EXA=true

# ==============================================================================
# Anthropic API Configuration (for AI recommendations)
# ==============================================================================
# Get your API key from: https://console.anthropic.com/
# Used for AI-powered prize recommendations to match participants with gifts
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ==============================================================================
# JWT Secret Key
# ==============================================================================
# CRITICAL: Change this in production!
# Generate a secure random key with: openssl rand -hex 32
# This key is used to sign JWT authentication tokens
JWT_SECRET_KEY=your-secure-random-secret-key-here

# ==============================================================================
# Database Configuration
# ==============================================================================
# SQLite is used by default - no configuration needed
# Database file: gift.db (auto-created on first run)
# For production, consider PostgreSQL instead

# ==============================================================================
# Application Settings
# ==============================================================================
# Add any additional environment variables here as needed
